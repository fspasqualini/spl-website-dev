---
import { brand, nav, withBase } from "../data/site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title = brand.name,
  description = "Synthetic Physiology Lab is a frontier bioengineering research group building instrumented cells, engineered tissue systems, computational models, and visual culture for life sciences.",
  image = brand.logo,
  imageAlt = "Synthetic Physiology Lab",
  jsonLd,
} = Astro.props;
const path = Astro.url.pathname;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const normalizedPath = path.startsWith(basePath) ? path.slice(basePath.length) || "/" : path;
const siteUrl = "https://syntheticphysiologylab.com";
const canonicalUrl = new URL(normalizedPath, siteUrl).toString();
const imageUrl = new URL(image, siteUrl).toString();
const pageTitle = title === brand.name ? brand.name + " | Frontier Bioengineering" : title;
const organizationId = `${siteUrl}/#organization`;
const websiteId = `${siteUrl}/#website`;
const organizationJsonLd = {
  "@context": "https://schema.org",
  "@type": "ResearchOrganization",
  "@id": organizationId,
  name: brand.name,
  alternateName: brand.shortName,
  url: `${siteUrl}/`,
  email: "francesco.pasqualini@unipv.it",
  logo: {
    "@type": "ImageObject",
    url: new URL(brand.logo, siteUrl).toString(),
    width: 600,
    height: 252,
  },
  description:
    "The Synthetic Physiology Lab at the University of Pavia is a bioengineering research group connecting instrumented cells, tissue systems, computational modeling and analysis, and art-science visual culture.",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Via Ferrata 9",
    postalCode: "27100",
    addressLocality: "Pavia",
    addressRegion: "PV",
    addressCountry: "IT",
  },
  parentOrganization: {
    "@type": "CollegeOrUniversity",
    name: "University of Pavia",
    url: "https://web-en.unipv.it/",
  },
  sameAs: [
    "https://dicar.dip.unipv.it/it/ricerca/linee-gruppi-e-laboratori-di-ricerca/laboratori-di-ricerca/spl",
    "https://github.com/Synthetic-Physiology-Lab",
    "https://twitter.com/LabPhysiology",
    "https://www.youtube.com/@SPL_UNIPV",
    "https://scholar.google.com/citations?user=9qFDVusAAAAJ&hl=en",
    "https://orcid.org/0000-0001-7038-3121",
  ],
};
const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": websiteId,
  url: `${siteUrl}/`,
  name: brand.name,
  alternateName: brand.shortName,
  description: "Official website of the Synthetic Physiology Lab at the University of Pavia.",
  publisher: { "@id": organizationId },
  about: { "@id": organizationId },
  inLanguage: "en",
};
const webpageJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${canonicalUrl}#webpage`,
  url: canonicalUrl,
  name: pageTitle,
  description,
  isPartOf: { "@id": websiteId },
  about: { "@id": organizationId },
  inLanguage: "en",
};
const pageJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const jsonLdItems = normalizedPath === "/"
  ? [organizationJsonLd, websiteJsonLd, webpageJsonLd, ...pageJsonLd]
  : [webpageJsonLd, ...pageJsonLd];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={brand.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:locale" content="en_GB" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />
    {jsonLdItems.map((item) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header">
      <a class="brand" href={withBase("/")} aria-label="Synthetic Physiology Lab home">
        <img
          src={withBase(brand.logo)}
          alt="Synthetic Physiology Lab"
          width="600"
          height="252"
          decoding="async"
        />
      </a>
      <nav class="nav" aria-label="Primary navigation">
        {nav.map((item) => (
          <a
            href={withBase(item.href)}
            class:list={[
              (item.href === "/" ? normalizedPath === "/" : normalizedPath.startsWith(item.href)) && "active",
            ]}
            aria-current={(item.href === "/" ? normalizedPath === "/" : normalizedPath.startsWith(item.href)) ? "page" : undefined}
          >{item.label}</a>
        ))}
      </nav>
    </header>
    <main id="main-content">
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <strong>{brand.name}</strong>
        <span>{brand.address}</span>
      </div>
      <span>© 2025-2030 Synthetic Physiology Lab</span>
    </footer>
  </body>
</html>
