---
import BaseLayout from "./BaseLayout.astro";
import { publications, withBase } from "../data/site";

const { area } = Astro.props;
const featuredPapers = area.featuredPapers ?? [];
const allPapers = area.paperTitles
  .map((title: string) => publications.find((paper) => paper.title === title))
  .filter(Boolean);
const carouselItems =
  area.featureCards ??
  featuredPapers
    .map((feature: { title: string; blurb: string; media: Array<{ type: string; src: string; label: string; text: string; href?: string }> }) => {
      const paper = publications.find((entry) => entry.title === feature.title);
      const media = feature.media[0];
      return media && paper
        ? {
            title: paper.title,
            text: feature.blurb,
            type: media.type,
            src: media.src,
            href: media.href ?? paper.href,
          }
        : null;
    })
    .filter(Boolean);
const resources = area.resources ?? [];
---

<BaseLayout title={area.title + " | Synthetic Physiology Lab"}>
  <section class="research-area-hero">
    <img src={withBase(area.image)} alt="" />
    <div>
      <a class="back-link" href={withBase("/research/")}>Research</a>
      <p class="eyebrow">Research area</p>
      <h1>{area.title}</h1>
      <p class="lead">{area.deepDive}</p>
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <div>
        <p class="eyebrow">Our</p>
        <h2>Unique vision</h2>
      </div>
      <div class="vision-panel">
        <p>{area.vision ?? area.deepDive}</p>
      </div>
    </div>
  </section>

  {carouselItems.length > 0 && (
  <section class="section band-soft carousel-section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Examples</p>
        <h2>In focus</h2>
      </div>
      <div class="feature-carousel" data-carousel aria-label={area.title + " featured examples"}>
        {carouselItems.map((item: { title: string; text: string; type: string; src: string; href?: string }, index: number) => (
          <article class:list={["feature-card", index === 0 && "active"]} data-carousel-card>
            <a href={item.href ?? item.src}>
              {item.type === "video" ? (
                <video src={withBase(item.src)} muted playsinline controls preload="metadata" />
              ) : (
                <img src={withBase(item.src)} alt="" loading="lazy" />
              )}
              <span>
                <strong>{item.title}</strong>
                <small>{item.text}</small>
              </span>
            </a>
          </article>
        ))}
        {carouselItems.length > 1 && (
          <div class="carousel-controls" aria-label="Carousel controls">
            <button type="button" data-carousel-prev aria-label="Previous example">&lt;</button>
            <div class="carousel-dots">
              {carouselItems.map((item: { title: string }, index: number) => (
                <button
                  type="button"
                  class:list={[index === 0 && "active"]}
                  data-carousel-dot={index}
                  aria-label={"Show " + item.title}
                  aria-current={index === 0 ? "true" : "false"}
                />
              ))}
            </div>
            <button type="button" data-carousel-next aria-label="Next example">&gt;</button>
          </div>
        )}
      </div>
    </div>
  </section>
  )}

  <section class="section">
    <div class="container split">
      <div>
        <p class="eyebrow">Related publications</p>
        <h2>All papers in this area</h2>
        <p>Including collaborations; listed newest to oldest.</p>
      </div>
      <div class="research-paper-list">
        {allPapers.map((paper) => (
          <a class="research-paper" href={paper.href}>
            <span class="tag">{paper.tag}</span>
            <strong>{paper.title}</strong>
            <span>{paper.authors}</span>
            <span>{paper.venue} · {paper.year}{paper.doi ? " · DOI " + paper.doi : ""}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {resources.length > 0 && (
  <section class="section">
    <div class="container split">
      <div>
        <p class="eyebrow">Tools and resources</p>
        <h2>Useful links</h2>
      </div>
      <div class="resource-list">
        {resources.map((resource: { label: string; href: string; text: string }) => (
          <a class="resource-item" href={resource.href}>
            <strong>{resource.label}</strong>
            <span>{resource.text}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
  )}

<script is:inline>
  const ROTATION_MS = 30000;

  document.querySelectorAll("[data-carousel]").forEach((carousel) => {
    const cards = Array.from(carousel.querySelectorAll("[data-carousel-card]"));
    const dots = Array.from(carousel.querySelectorAll("[data-carousel-dot]"));
    const previous = carousel.querySelector("[data-carousel-prev]");
    const next = carousel.querySelector("[data-carousel-next]");
    let active = 0;
    let timer;

    const setActive = (index) => {
      active = (index + cards.length) % cards.length;
      cards.forEach((card, cardIndex) => {
        card.classList.toggle("active", cardIndex === active);
      });
      dots.forEach((dot, dotIndex) => {
        const isActive = dotIndex === active;
        dot.classList.toggle("active", isActive);
        dot.setAttribute("aria-current", isActive ? "true" : "false");
      });
    };

    const stop = () => {
      if (timer) window.clearInterval(timer);
    };

    const start = () => {
      stop();
      if (cards.length > 1) {
        timer = window.setInterval(() => setActive(active + 1), ROTATION_MS);
      }
    };

    previous?.addEventListener("click", () => {
      setActive(active - 1);
      start();
    });

    next?.addEventListener("click", () => {
      setActive(active + 1);
      start();
    });

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        setActive(Number(dot.getAttribute("data-carousel-dot")));
        start();
      });
    });

    carousel.addEventListener("mouseenter", stop);
    carousel.addEventListener("mouseleave", start);
    setActive(0);
    start();
  });
</script>
</BaseLayout>
