---
import BaseLayout from "../layouts/BaseLayout.astro";
import { fundedProjects, getImageDimensions, heroStats, labVisionSections, withBase } from "../data/site";
import { categoryLabels, formatNewsDate, homepageNews } from "../data/news";
---

<BaseLayout
  title="Synthetic Physiology Lab | University of Pavia"
  description="Official website of Synthetic Physiology Lab (SPL), the Pasqualini Lab at the University of Pavia, building instrumented cells, tissues, and computational models."
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">University of Pavia</p>
      <h1>
        <span><span class="hero-initial">S</span>ynthetic</span>
        <span><span class="hero-initial">P</span>hysiology</span>
        <span><span class="hero-initial">L</span>ab</span>
      </h1>
      <p class="lead">
        We build physiology through instrumented cells, tissue systems, computational modeling and analysis, and the visual culture that helps make complex biology thinkable.
      </p>
      <div class="stats" aria-label="Lab highlights">
        {heroStats.map((stat) => (
          <div class="stat">
            <strong>{stat.value}</strong>
            <span>{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
    <aside class="news-rail hero-news" aria-label="Latest SPL news">
      <div class="news-rail-header">
        <div>
          <p class="eyebrow">Latest from SPL</p>
          <h2>Lab pulse.</h2>
        </div>
        <a href={withBase("/news/")}>All news</a>
      </div>
      <div class="news-rail-list">
        {homepageNews.map((entry) => (
          <article class="news-rail-item">
            <div class="news-rail-copy">
              <div class="news-rail-meta">
                <span class="news-category">{categoryLabels[entry.category]}</span>
                <time class="news-date" datetime={entry.date}>{formatNewsDate(entry)}</time>
              </div>
              <h3>
                <a href={withBase(`/news/${entry.date.slice(0, 4)}/#${entry.id}`)}>{entry.title}</a>
              </h3>
              <p>{entry.blurb}</p>
            </div>
          </article>
        ))}
      </div>
    </aside>
  </section>

  <section class="section">
    <div class="container thesis-grid">
      <div class="thesis-heading">
        <p class="eyebrow">Lab vision</p>
        <h2>
          <span>Understanding</span>
          <span>Physiology</span>
          <span>by building it.</span>
        </h2>
        <p class="vision-intro">
          Synthetic Physiology Lab (SPL), led by Francesco S. Pasqualini, is a frontier bioengineering research group at the University of Pavia (UniPV). We treat engineering, computation, and visual culture as one experimental loop: cells, tissues, models, and images that make physiology observable, testable, and open to revision.
        </p>
        <div class="cta-row">
          <a class="cta" href={withBase("/research/")}>More about our research</a>
        </div>
      </div>
      <div class="copy-stack">
        {labVisionSections.map((message) => (
          <article class="copy-message">
            <h3>{message.title}</h3>
            <p>{message.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section band-dark">
    <div class="container split">
      <div>
        <p class="eyebrow">Funded work</p>
        <h2>Programs with a bias toward buildable biology.</h2>
      </div>
      <div class="funded-programs">
        {fundedProjects.map((project) => (
          <article class="funded-program-card">
            <div class="funded-card-header">
              <div class="funder-logos" aria-label="Funding bodies">
                {project.logos.map((logo) => (
                  <img
                    src={withBase(logo.src)}
                    alt={logo.alt}
                    width={getImageDimensions(logo.src)?.width}
                    height={getImageDimensions(logo.src)?.height}
                    loading="lazy"
                    decoding="async"
                  />
                ))}
              </div>
            </div>
            <h3>{project.title}</h3>
            <p>{project.subtitle}</p>
            <div class="meta">
              <span>{project.funder}</span>
              <span>{project.amount}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
