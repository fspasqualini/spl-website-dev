---
import BaseLayout from "../layouts/BaseLayout.astro";
import { team, withBase } from "../data/site";
---

<BaseLayout title="Team | Synthetic Physiology Lab">
  <section class="section">
    <div class="container">
      <p class="eyebrow">Team</p>
      <h1>Scientists, engineers, artists: come build with us.</h1>
      <p class="lead">Like building for the life sciences, not just studying them? Read our creed and see if this is your kind of work.</p>
      <div class="people-grid">
        {team.map((person) => (
          <article class="person">
            <img src={withBase(person.image)} alt={person.name} />
            <div>
              <h3>{person.name}</h3>
              <p><strong>{person.role}</strong></p>
              <p>{person.focus}</p>
              <a href={`mailto:${person.email}`}>{person.email}</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
