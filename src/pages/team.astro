---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getImageDimensions, team, withBase } from "../data/site";
---

<BaseLayout
  title="Team | Synthetic Physiology Lab"
  description="Meet the scientists, engineers, artists, and builders behind Synthetic Physiology Lab, a frontier bioengineering group at the University of Pavia."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Team</p>
      <h1>Scientists, engineers, artists: come build with us.</h1>
      <p class="lead">Like building for the life sciences, not just studying them? Read our creed and see if this is your kind of work.</p>
      <div class="people-grid">
        {team.map((person) => (
          <article class="person">
            <img
              src={withBase(person.image)}
              alt={`${person.name}, ${person.role} at Synthetic Physiology Lab`}
              width={getImageDimensions(person.image)?.width}
              height={getImageDimensions(person.image)?.height}
              loading="lazy"
              decoding="async"
            />
            <div>
              <h3>{person.name}</h3>
              <p><strong>{person.role}</strong></p>
              <p>{person.focus}</p>
              <a href={`mailto:${person.email}`}>{person.email}</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
