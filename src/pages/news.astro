---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../data/site";
import { newsItems } from "../data/news";
---

<BaseLayout
  title="News | Synthetic Physiology Lab"
  description="News from Synthetic Physiology Lab: publications, preprints, grants, awards, software, datasets, and frontier bioengineering updates from the University of Pavia."
>
  <section class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Lab feed</p>
        <h1>Recent SPL updates.</h1>
        <p class="lead">
          Peer-reviewed articles, preprints, grants, personnel changes, awards, software, datasets, and resources in one structured feed.
        </p>
      </div>
      <div class="news-list">
        {newsItems.map((item) => (
          <article class:list={["news-item", item.image && "news-item-with-image"]}>
            <span class="tag" data-category={item.label.category}>{item.label.text}</span>
            <div>
              {item.image && (
                <figure class="news-item-figure">
                  {item.image.src ? (
                    <img src={withBase(item.image.src)} alt={item.image.alt} />
                  ) : (
                    <div class="news-image-placeholder" aria-label={item.image.alt}>
                      <span>Photo pending</span>
                    </div>
                  )}
                  {item.image.caption && <figcaption>{item.image.caption}</figcaption>}
                </figure>
              )}
              <div class="news-item-copy">
                <p class="news-date">{item.date}</p>
                <h3>
                  {item.href ? <a href={item.href}>{item.title}</a> : item.title}
                </h3>
                <p>{item.text}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
