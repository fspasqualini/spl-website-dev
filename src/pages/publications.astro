---
import BaseLayout from "../layouts/BaseLayout.astro";
import { publications } from "../data/site";
---

<BaseLayout title="Publications | Synthetic Physiology Lab">
  <section class="section">
    <div class="container">
      <div>
        <p class="eyebrow">Publications</p>
        <h1>All SPL papers and preprints.</h1>
        <p class="lead">A chronological list from the most recent work to the earliest publications. Short highlight selections belong on the home page.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Chronological inventory</p>
        <h2>{publications.length} papers and preprints</h2>
      </div>
      <div class="inventory-list">
        {publications.map((paper) => (
          <article class="inventory-paper">
            <span class="tag">{paper.tag}</span>
            <div>
              <h3><a href={paper.href}>{paper.title}</a></h3>
              <p>{paper.authors}</p>
              <p><strong>{paper.venue}</strong> · {paper.year}{paper.doi ? " · DOI " + paper.doi : ""}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
