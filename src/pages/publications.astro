---
import BaseLayout from "../layouts/BaseLayout.astro";
import { publications } from "../data/site";
import { getPublicationLabels } from "../data/labels";
---

<BaseLayout title="Publications | Synthetic Physiology Lab">
  <section class="section">
    <div class="container">
      <div>
        <p class="eyebrow">Publications</p>
        <h1>All SPL publications.</h1>
        <p class="lead">A chronological list from the most recent work to the earliest publications. Research-theme metadata stays in the database for routing papers into lab areas.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Chronological inventory</p>
        <h2>{publications.length} publications</h2>
      </div>
      <div class="inventory-list">
        {publications.map((paper) => {
          const labels = getPublicationLabels(paper);
          const detailLabels = labels.primary.id === labels.status.id ? [] : [labels.status.text];
          return (
          <article class="inventory-paper">
            <div class="label-stack">
              <span class="tag" data-category={labels.primary.category} data-label-id={labels.primary.id}>{labels.primary.text}</span>
              <span class="provenance-tag" data-provenance={labels.provenance.id}>{labels.provenance.text}</span>
              {detailLabels.length > 0 && <span class="label-detail">{detailLabels.join(" · ")}</span>}
            </div>
            <div>
              <h3><a href={paper.href}>{paper.title}</a></h3>
              <p>{paper.authors}</p>
              <p><strong>{paper.venue}</strong> · {paper.year}{paper.doi ? " · DOI " + paper.doi : ""}</p>
            </div>
          </article>
        )})}
      </div>
    </div>
  </section>
</BaseLayout>
