---
import BaseLayout from "../layouts/BaseLayout.astro";
import { publications } from "../data/site";
import { getPublicationLabels } from "../data/labels";
---

<BaseLayout
  title="Publications | Synthetic Physiology Lab"
  description="Publications from Synthetic Physiology Lab and Francesco S. Pasqualini on bioengineering, engineered cells, tissue systems, mechanobiology, computational modeling, and art-science."
>
  <section class="section">
    <div class="container">
      <div>
        <p class="eyebrow">Research</p>
        <h1>Publications.</h1>
        <p class="lead">A chronological record of peer-reviewed articles, preprints, and selected earlier work from the PI's postdoctoral training at Harvard's Wyss Institute and the Wyss Zurich Translational Center.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="inventory-list">
        {publications.map((paper) => {
          const labels = getPublicationLabels(paper);
          const detailLabels = labels.primary.id === labels.status.id ? [] : [labels.status.text];
          return (
          <article class="inventory-paper">
            <div class="label-stack">
              <span class="tag" data-category={labels.primary.category} data-label-id={labels.primary.id}>{labels.primary.text}</span>
              <span class="provenance-tag" data-provenance={labels.provenance.id}>{labels.provenance.text}</span>
              {detailLabels.length > 0 && <span class="label-detail">{detailLabels.join(" · ")}</span>}
            </div>
            <div>
              <h3><a href={paper.href}>{paper.title}</a></h3>
              <p>{paper.authors}</p>
              <p><strong>{paper.venue}</strong> · {paper.year}{paper.doi ? " · DOI " + paper.doi : ""}</p>
            </div>
          </article>
        )})}
      </div>
    </div>
  </section>
</BaseLayout>
